RUN apk add --no-cache nodejs npm

# Install TypeScript language server and Prettier for formatting
RUN npm install -g typescript-language-server typescript prettier

# Copy JavaScript/TypeScript specific configuration
RUN mkdir -p .emacs.d/init.d
COPY modes/js/.emacs.d/init.d/js.el .emacs.d/init.d/js.el

